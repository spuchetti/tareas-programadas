def inicializar_drive():
    try:
        cfg = json.loads(os.getenv("GDRIVE_JSON"))
        creds = Credentials.from_service_account_info(
            cfg,
            scopes=[
                "https://www.googleapis.com/auth/drive",
                "https://www.googleapis.com/auth/spreadsheets",
            ],
        )
        return build("drive", "v3", credentials=creds, cache_discovery=False)
    except Exception as e:
        print(f"❌ Error iniciando Drive: {e}")
        traceback.print_exc()
        return None


def listar_archivos_xlsx(drive, carpeta_id):
    mime_xlsx = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    q = (
        f"'{carpeta_id}' in parents and trashed=false and ("
        f"name contains '.xlsx' or mimeType='{mime_xlsx}')"
    )
    archivos, page_token = [], None
    while True:
        res = drive.files().list(
            q=q, pageSize=200,
            fields="nextPageToken, files(id, name, mimeType, modifiedTime)",
            supportsAllDrives=True, includeItemsFromAllDrives=True,
            pageToken=page_token,
        ).execute()
        archivos.extend(res.get("files", []))
        page_token = res.get("nextPageToken")
        if not page_token:
            break
    return archivos


def listar_snaps(drive, snap_folder_id):
    """Devuelve dict {nombre_snap: {id, modifiedTime}}."""
    q = f"'{snap_folder_id}' in parents and trashed=false"
    archivos, page_token = [], None
    while True:
        res = drive.files().list(
            q=q, pageSize=200,
            fields="nextPageToken, files(id, name, modifiedTime)",
            supportsAllDrives=True, includeItemsFromAllDrives=True,
            pageToken=page_token,
        ).execute()
        archivos.extend(res.get("files", []))
        page_token = res.get("nextPageToken")
        if not page_token:
            break
    return {a["name"]: a for a in archivos}


def obtener_o_crear_carpeta_snaps(drive):
    res = drive.files().list(
        q=(
            f"'{CARPETA_INTERNA_ID}' in parents "
            f"and name='{SNAP_FOLDER_NAME}' "
            f"and mimeType='application/vnd.google-apps.folder' "
            f"and trashed=false"
        ),
        fields="files(id)",
        supportsAllDrives=True, includeItemsFromAllDrives=True,
    ).execute()
    lst = res.get("files", [])
    if lst:
        fid = lst[0]["id"]
        print(f"📁 Carpeta snapshots: {fid}")
        return fid
    nueva = drive.files().create(
        body={
            "name": SNAP_FOLDER_NAME,
            "mimeType": "application/vnd.google-apps.folder",
            "parents": [CARPETA_INTERNA_ID],
        },
        fields="id", supportsAllDrives=True,
    ).execute()
    print(f"📁 Carpeta snapshots creada: {nueva['id']}")
    return nueva["id"]


def descargar_xlsx(drive, file_id, mime_type):
    try:
        if mime_type == "application/vnd.google-apps.spreadsheet":
            req = drive.files().export_media(
                fileId=file_id,
                mimeType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            )
        else:
            req = drive.files().get_media(fileId=file_id)
        fh = io.BytesIO()
        downloader = MediaIoBaseDownload(fh, req)
        done = False
        while not done:
            _, done = downloader.next_chunk()
        fh.seek(0)
        return fh
    except Exception as e:
        print(f"   ❌ Error descargando: {e}")
        return None


def descargar_snap_xlsx(drive, snap_id):
    """Exporta el SNAP (Google Sheets) como XLSX."""
    return descargar_xlsx(
        drive, snap_id,
        "application/vnd.google-apps.spreadsheet",
    )


def actualizar_snap(drive, fh_xlsx, nombre_snap, snap_folder_id, snap_id_existente=None):
    """
    Sube el XLSX como Google Sheets en la carpeta de snaps.
    Si ya existe uno previo, lo manda a la papelera primero.
    """
    if snap_id_existente:
        try:
            drive.files().update(
                fileId=snap_id_existente,
                body={"trashed": True},
                supportsAllDrives=True,
            ).execute()
        except Exception:
            pass

    fh_xlsx.seek(0)
    media = MediaIoBaseUpload(
        fh_xlsx,
        mimetype="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        resumable=True,
    )
    for intento in range(INTENTOS_MAX):
        try:
            resultado = drive.files().create(
                body={
                    "name": nombre_snap,
                    "mimeType": "application/vnd.google-apps.spreadsheet",
                    "parents": [snap_folder_id],
                },
                media_body=media,
                fields="id",
                supportsAllDrives=True,
            ).execute()
            return resultado["id"]
        except HttpError as e:
            if e.resp.status in (403, 429, 500, 503):
                espera = ESPERA_REINTENTO * (intento + 1)
                print(f"   ⏳ Error {e.resp.status}, reintento {intento+1}/{INTENTOS_MAX} en {espera}s...")
                time.sleep(espera)
            else:
                raise
    return None


# ---------------------------------------------------------------------------
# Obtener nombre de hoja tolerante a variantes (° vs º)
# ---------------------------------------------------------------------------

def _normalizar_nombre_hoja(s):
    return s.lower().replace("°", "@").replace("º", "@").replace(" ", "").strip()


def obtener_hoja(wb, nombre_buscado):
    objetivo = _normalizar_nombre_hoja(nombre_buscado)
    for nombre in wb.sheetnames:
        if _normalizar_nombre_hoja(nombre) == objetivo:
            return wb[nombre]
    return None


# ---------------------------------------------------------------------------
# Leer datos de un workbook openpyxl
# ---------------------------------------------------------------------------

def leer_datos_hoja(ws, fila_inicio):
    """
    Lee filas desde fila_inicio, columnas COL_INICIO..COL_FIN.
    Filtra filas donde el DNI (col_idx=1, 0-based offset) esté vacío o sea '-'.
    Devuelve lista de listas de strings/floats (valores crudos).
    """
    col_inicio = CONFIG["COL_INICIO"]      # 1-based
    col_fin    = CONFIG["COL_FIN"]         # 1-based
    col_dni_offset = CONFIG["COL_DNI"] - col_inicio   # 0-based dentro del rango

    filas = []
    for row in ws.iter_rows(
        min_row=fila_inicio, min_col=col_inicio, max_col=col_fin, values_only=True
    ):
        if all(c is None for c in row):
            break
        dni = str(row[col_dni_offset] or "").strip()
        if dni in ("", "-", "0"):
            continue
        filas.append(list(row))
    return filas


# ---------------------------------------------------------------------------
# Procesar un archivo
# ---------------------------------------------------------------------------

def procesar_archivo(drive, sheets_svc, archivo, snap_info, snap_folder_id, snaps_dict):
    nombre    = archivo["name"]
    es_caja   = "caja" in nombre.lower()
    fila_ini  = CONFIG["FILA_INICIO_CAJA"] if es_caja else CONFIG["FILA_INICIO_DEFAULT"]
    nombre_base = nombre.replace(".xlsx", "").replace(".XLSX", "")
    nombre_snap = f"{SNAP_PREFIX}{nombre_base}"

    # ── 1. Chequeo de fecha: ¿cambió el archivo desde el último SNAP? ──
    snap_info_actual = snaps_dict.get(nombre_snap)
    if snap_info_actual:
        mod_xlsx = archivo.get("modifiedTime", "")
        mod_snap = snap_info_actual.get("modifiedTime", "")
        if mod_xlsx and mod_snap and mod_xlsx <= mod_snap:
            print(f"  ⏭️  {nombre}: sin cambios.")
            return "skip"

    print(f"  📄 {nombre}: procesando...")

    # ── 2. Descargar XLSX actual ──
    fh_actual = descargar_xlsx(drive, archivo["id"], archivo["mimeType"])
    if not fh_actual:
        raise RuntimeError("No se pudo descargar el archivo.")

    wb_actual = openpyxl.load_workbook(fh_actual, data_only=True, read_only=True)

    # ── 3. Hoja de registro de agentes ──
    hoja_registro = obtener_o_crear_hoja_registro(sheets_svc, nombre)

    # Registrar/actualizar agentes del archivo actual
    col_dni_offset = CONFIG["COL_DNI"] - CONFIG["COL_INICIO"]
    for nombre_hoja in HOJAS_ORDEN:
        ws = obtener_hoja(wb_actual, nombre_hoja)
        if not ws:
            continue
        for fila in leer_datos_hoja(ws, fila_ini):
            cuil   = str(fila[0] or "").strip()
            dni    = str(fila[col_dni_offset] or "").strip()
            nombre_ag = str(fila[3] or "").strip()
            if cuil or dni or nombre_ag:
                obtener_id_agente(cuil, dni, nombre_ag, hoja_registro)

    # ── 4. Sin SNAP previo → guardar SNAP inicial y salir ──
    if not snap_info_actual:
        fh_actual.seek(0)
        nuevo_id = actualizar_snap(drive, fh_actual, nombre_snap, snap_folder_id, None)
        wb_actual.close()
        if nuevo_id:
            snaps_dict[nombre_snap] = {"id": nuevo_id, "modifiedTime": ""}
        print(f"  ✅ {nombre}: snapshot inicial creado.")
        return "procesado"

    # ── 5. Descargar SNAP anterior y comparar ──
    fh_snap = descargar_snap_xlsx(drive, snap_info_actual["id"])
    if not fh_snap:
        raise RuntimeError("No se pudo descargar el SNAP.")
    wb_snap = openpyxl.load_workbook(fh_snap, data_only=True, read_only=True)

    cambios_por_hoja = []
    reparticion = extraer_reparticion(nombre)
    anio        = extraer_anio_desde_nombre(nombre)

    for nombre_hoja in HOJAS_ORDEN:
        ws_actual = obtener_hoja(wb_actual, nombre_hoja)
        ws_snap   = obtener_hoja(wb_snap,   nombre_hoja)
        if not ws_actual or not ws_snap:
            continue

        datos_actual = leer_datos_hoja(ws_actual, fila_ini)
        datos_snap   = leer_datos_hoja(ws_snap,   fila_ini)

        if es_caja:
            resultado = compararHojasCaja(datos_actual, datos_snap, hoja_registro)
        else:
            resultado = compararHojasNormal(datos_actual, datos_snap, hoja_registro)

        cambios  = resultado["cambios"]
        mapa_act = resultado["mapa_actual"]

        if cambios:
            # Si el snap estaba vacío → carga inicial, sin reporte
            if not datos_snap and datos_actual:
                print(f"  → {nombre_hoja}: carga inicial, sin reporte.")
                continue
            cambios_por_hoja.append({
                "hoja": nombre_hoja,
                "cambios": cambios,
                "mapa_actual": mapa_act,
            })

    wb_actual.close()
    wb_snap.close()

    # ── 6. Generar adjuntos + mail + actualizar SNAP ──
    if cambios_por_hoja:
        adjuntos_rutas = _generar_adjuntos(cambios_por_hoja, reparticion, anio, nombre, es_caja)
        enviar_mail_cambios(nombre, cambios_por_hoja, es_caja, reparticion, anio, adjuntos_rutas)
        # Actualizar SNAP solo después del mail exitoso
        fh_actual.seek(0)
        nuevo_id = actualizar_snap(
            drive, fh_actual, nombre_snap, snap_folder_id, snap_info_actual["id"]
        )
        if nuevo_id:
            snaps_dict[nombre_snap] = {"id": nuevo_id, "modifiedTime": ""}
        total = sum(len(h["cambios"]) for h in cambios_por_hoja)
        print(f"  ✅ {nombre}: {total} cambios notificados.")
    else:
        fh_actual.seek(0)
        actualizar_snap(
            drive, fh_actual, nombre_snap, snap_folder_id, snap_info_actual["id"]
        )
        print(f"  ✅ {nombre}: sin cambios reportables.")

    return "procesado"


# ---------------------------------------------------------------------------
# Generar adjuntos en disco temporal
# ---------------------------------------------------------------------------

def _generar_adjuntos(cambios_por_hoja, reparticion, anio, nombre_archivo, es_caja):
    """
    Genera los archivos adjuntos en /tmp y devuelve lista de rutas.
    """
    os.makedirs("/tmp/monitoreo", exist_ok=True)
    rutas = []

    for bloque in cambios_por_hoja:
        nombre_hoja = bloque["hoja"]
        cambios     = bloque["cambios"]
        mapa_actual = bloque["mapa_actual"]
        periodo     = hoja_a_periodo(nombre_hoja, anio)

        modifs = [c for c in cambios if c["tipo"] == "modificado"]
        elims  = [c for c in cambios if c["tipo"] == "eliminado"]
        nuevos = [c for c in cambios if c["tipo"] == "nuevo"]

        # Adjunto 1: XLSX de cambios
        if modifs or elims or nuevos:
            ruta_xlsx = f"/tmp/monitoreo/Modificaciones_{normalizar_nombre(reparticion)}_{normalizar_periodo(periodo)}.xlsx"
            generar_xlsx_cambios(modifs, elims, nuevos, periodo, reparticion, ruta_xlsx)
            rutas.append(ruta_xlsx)

        # Adjunto 2: CSV modificados/nuevos
        if modifs or nuevos:
            ruta_csv = f"/tmp/monitoreo/Modificaciones_{normalizar_nombre(reparticion)}_{normalizar_periodo(periodo)}.csv"
            generar_csv_modificados(modifs, nuevos, ruta_csv)
            rutas.append(ruta_csv)

        # Adjunto 3: CSV complementarias (solo modo normal)
        if not es_caja:
            ruta_comp = f"/tmp/monitoreo/Complementarias_{normalizar_nombre(reparticion)}_{normalizar_periodo(periodo)}.csv"
            hay_comp = generar_csv_complementarias(mapa_actual, ruta_comp)
            if hay_comp:
                rutas.append(ruta_comp)

        # Adjunto 4: CSV liquidación completa (ordinarias en normal, todas en caja)
        ruta_rect = f"/tmp/monitoreo/Rectificativa_{normalizar_nombre(reparticion)}_{normalizar_periodo(periodo)}.csv"
        generar_csv_liquidacion_completa(mapa_actual, es_caja, ruta_rect)
        rutas.append(ruta_rect)

    return rutas


