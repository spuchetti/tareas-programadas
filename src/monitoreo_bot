def ejecutar_principal():
    inicio = time.time()
    registrar_inicio("BOT MONITOREO DE LIQUIDACIONES")

    drive = inicializar_drive()
    if not drive:
        return

    sheets_svc = inicializar_sheets()
    if not sheets_svc:
        print("❌ No se pudo inicializar Sheets.")
        return

    snap_folder_id = obtener_o_crear_carpeta_snaps(drive)
    snaps_dict     = listar_snaps(drive, snap_folder_id)
    archivos       = listar_archivos_xlsx(drive, CARPETA_XLSX_ID)

    print(f"📊 Archivos: {len(archivos)}  |  SNAPs existentes: {len(snaps_dict)}")
    print("═" * 60)

    procesados, saltados, errores = 0, 0, 0

    for i, archivo in enumerate(archivos, 1):
        print(f"[{i}/{len(archivos)}] {archivo['name']}")
        try:
            res = procesar_archivo(
                drive, sheets_svc, archivo, None, snap_folder_id, snaps_dict
            )
            if res == "skip":
                saltados += 1
            else:
                procesados += 1
        except Exception as e:
            errores += 1
            print(f"  ❌ Error: {e}")
            traceback.print_exc()

        if i < len(archivos):
            time.sleep(PAUSA_ENTRE_ARCH)

    print("═" * 60)
    registrar_resumen(inicio, procesados + saltados, len(archivos))
    print(f"✅ Procesados: {procesados}  |  ⏭️  Sin cambios: {saltados}  |  ❌ Errores: {errores}")


if __name__ == "__main__":
    ejecutar_principal()