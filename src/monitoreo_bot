def normalizar_texto(s):
    import unicodedata
    t = str(s or "").upper()
    t = unicodedata.normalize("NFD", t)
    t = "".join(c for c in t if unicodedata.category(c) != "Mn")
    return " ".join(t.split())

def limpiar_numero(s):
    return re.sub(r"[^0-9]", "", str(s or ""))

